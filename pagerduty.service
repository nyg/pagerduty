[Unit]
Description=PagerDuty Incident Dashboard
After=network.target

[Service]
Type=simple
User=pagerduty
Group=pagerduty
WorkingDirectory=/opt/pagerduty
ExecStart=/bin/bash -lc 'source ~/.nvm/nvm.sh 2>/dev/null; npm --prefix /opt/pagerduty start'
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal
SyslogIdentifier=pagerduty
EnvironmentFile=-/opt/pagerduty/.env.local

[Install]
WantedBy=multi-user.target
